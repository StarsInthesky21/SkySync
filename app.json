{
  "expo": {
    "name": "SkySync",
    "slug": "skysync",
    "scheme": "skysync",
    "version": "1.3.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skysync.app",
      "buildNumber": "5",
      "associatedDomains": ["applinks:skysync.app"],
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SkySync uses your location to show exactly what stars and planets are visible from where you are right now.",
        "NSMicrophoneUsageDescription": "SkySync uses the microphone for Sky Room voice sessions.",
        "NSCameraUsageDescription": "SkySync uses the camera for the AR sky view."
      }
    },
    "android": {
      "package": "com.skysync.app",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#04111f"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "skysync" },
            { "scheme": "https", "host": "skysync.app", "pathPrefix": "/room" },
            { "scheme": "https", "host": "skysync.app", "pathPrefix": "/object" },
            { "scheme": "https", "host": "skysync.app", "pathPrefix": "/constellation" },
            { "scheme": "https", "host": "skysync.app", "pathPrefix": "/learn/story" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageResizeMode": "contain",
          "backgroundColor": "#04111f",
          "dark": {
            "backgroundColor": "#04111f",
            "image": "./assets/icon.png"
          }
        }
      ],
      "expo-router",
      "expo-dev-client",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SkySync uses your location to show exactly what stars and planets are visible from where you are right now."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#73fbd3"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "SkySync uses the camera for the AR sky view so you can point your phone at the sky to identify stars and planets."
        }
      ]
    ],
    "extra": {
      "firebaseEnabled": false,
      "router": {},
      "eas": {
        "projectId": "a9d1efc6-1546-4b00-8fce-a89cc1462930"
      }
    },
    "owner": "mangochess08"
  }
}
