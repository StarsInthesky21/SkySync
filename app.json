{
  "expo": {
    "name": "SkySync",
    "slug": "skysync",
    "scheme": "skysync",
    "version": "1.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.skysync.app",
      "buildNumber": "4",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SkySync uses your location to show exactly what stars and planets are visible from where you are right now."
      }
    },
    "android": {
      "package": "com.skysync.app",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#04111f"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageResizeMode": "contain",
          "backgroundColor": "#04111f",
          "dark": {
            "backgroundColor": "#04111f",
            "image": "./assets/icon.png"
          }
        }
      ],
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SkySync uses your location to show exactly what stars and planets are visible from where you are right now."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#73fbd3"
        }
      ]
    ],
    "extra": {
      "firebaseEnabled": false,
      "router": {},
      "eas": {
        "projectId": "a9d1efc6-1546-4b00-8fce-a89cc1462930"
      }
    },
    "owner": "mangochess08"
  }
}
