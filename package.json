{
  "name": "skysync",
  "version": "1.3.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "EXPO_NO_TELEMETRY=1 expo start",
    "start:offline": "EXPO_NO_TELEMETRY=1 expo start --offline",
    "web": "EXPO_NO_TELEMETRY=1 expo start --web",
    "build:web": "EXPO_NO_TELEMETRY=1 expo export --platform web",
    "deploy:web": "npm run build:web && gh-pages -d dist",
    "prebuild": "EXPO_NO_TELEMETRY=1 expo prebuild",
    "android": "EXPO_NO_TELEMETRY=1 expo start --android",
    "ios": "EXPO_NO_TELEMETRY=1 expo start --ios",
    "typecheck": "tsc --noEmit",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "e2e": "./scripts/e2e-local.sh"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@expo/prebuild-config": "^55.0.14",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-community/slider": "^4.5.5",
    "debug": "^4.4.3",
    "expo": "~53.0.0",
    "expo-application": "~6.1.5",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-device": "~7.1.4",
    "expo-haptics": "~14.1.4",
    "expo-linking": "~7.1.7",
    "expo-location": "~18.1.6",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.11",
    "expo-sensors": "~14.1.4",
    "expo-speech": "~13.1.7",
    "expo-splash-screen": "~0.30.10",
    "expo-status-bar": "~2.2.3",
    "firebase": "^11.10.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.2",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-web": "^0.20.0"
  },
  "optionalDependencies": {
    "livekit-client": "^2.5.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.0.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "getenv": "^1.0.0",
    "gh-pages": "^6.3.0",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.0",
    "prettier": "^3.3.0",
    "react-test-renderer": "19.0.0",
    "typescript": "~5.8.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "testPathIgnorePatterns": [
      "<rootDir>/node_modules/",
      "<rootDir>/src/__tests__/helpers/"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)/|expo(nent)?/|expo-[^/]*/|@expo(nent)?/.*|expo-modules-core/|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@react-native-async-storage/.*|@react-native-community/.*)"
    ],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/__tests__/**",
      "!src/services/firebase/**",
      "!src/services/voip/**"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 42,
        "branches": 28,
        "functions": 40,
        "lines": 43
      }
    }
  }
}
