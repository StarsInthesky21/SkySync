{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2022",
    "lib": ["es2022"],
    "moduleResolution": "node",
    "outDir": "lib",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitReturns": true,
    "sourceMap": true,
    "declaration": false,
    "types": ["node"]
  },
  "include": ["*.ts"],
  "exclude": ["lib", "node_modules"]
}
